<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_product_management_tree" model="ir.ui.view">
        <field name="name">product.management.tree</field>
        <field name="model">product.management</field>
        <field name="arch" type="xml">
            <tree string="Sản phẩm">
                <field name="code"/>
                <field name="name"/>
                <field name="category"/>
                <field name="price"/>
                <field name="cost"/>
                <field name="profit"/>
                <field name="quantity"/>
                <field name="state" widget="badge" decoration-success="state=='available'" decoration-danger="state=='out_of_stock'" decoration-info="state=='draft'"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_product_management_form" model="ir.ui.view">
        <field name="name">product.management.form</field>
        <field name="model">product.management</field>
        <field name="arch" type="xml">
            <form string="Sản phẩm">
                <header>
                    <button name="action_set_available" string="Đặt có sẵn" type="object" class="oe_highlight" invisible="state == 'available'"/>
                    <button name="action_set_out_of_stock" string="Đặt hết hàng" type="object" class="oe_highlight" invisible="state == 'out_of_stock'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,available,out_of_stock"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên sản phẩm..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="price"/>
                            <field name="cost"/>
                            <field name="profit"/>
                            <field name="quantity"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả">
                            <field name="description" placeholder="Nhập mô tả chi tiết về sản phẩm..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_product_management_search" model="ir.ui.view">
        <field name="name">product.management.search</field>
        <field name="model">product.management</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm sản phẩm">
                <field name="name" string="Sản phẩm" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="category"/>
                <separator/>
                <filter string="Có sẵn" name="available" domain="[('state', '=', 'available')]"/>
                <filter string="Hết hàng" name="out_of_stock" domain="[('state', '=', 'out_of_stock')]"/>
                <filter string="Nháp" name="draft" domain="[('state', '=', 'draft')]"/>
                <separator/>
                <filter string="Hoạt động" name="active" domain="[('active', '=', True)]"/>
                <filter string="Không hoạt động" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Danh mục" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Trạng thái" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_product_management" model="ir.actions.act_window">
        <field name="name">Sản phẩm</field>
        <field name="res_model">product.management</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo sản phẩm đầu tiên
            </p>
            <p>
                Nhấn vào nút Tạo để thêm sản phẩm mới vào hệ thống.
            </p>
        </field>
    </record>
</odoo>
