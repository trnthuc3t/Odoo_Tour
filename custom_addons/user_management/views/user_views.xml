<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record id="view_user_profile_list" model="ir.ui.view">
            <field name="name">user.profile.list</field>
            <field name="model">user.profile</field>
            <field name="arch" type="xml">
                <tree string="Danh sách Users" multi_edit="1">
                    <field name="image" widget="image" options="{'size': [32, 32]}"/>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="active" column_invisible="1"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_user_profile_form" model="ir.ui.view">
            <field name="name">user.profile.form</field>
            <field name="model">user.profile</field>
            <field name="arch" type="xml">
                <form string="User">
                    <sheet>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="Họ và tên..."/></h1>
                        </div>
                        <group>
                            <field name="email" placeholder="email@example.com"/>
                            <field name="phone" placeholder="Số điện thoại..."/>
                            <field name="active"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Mật khẩu">
                            <field name="password" password="True" placeholder="Nhập mật khẩu mới..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action kích hoạt hàng loạt -->
        <record id="action_activate_users" model="ir.actions.server">
            <field name="name">Kích hoạt</field>
            <field name="model_id" ref="model_user_profile"/>
            <field name="binding_model_id" ref="model_user_profile"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">records.action_activate()</field>
        </record>

        <!-- Action archived hàng loạt -->
        <record id="action_archive_users" model="ir.actions.server">
            <field name="name">Archived</field>
            <field name="model_id" ref="model_user_profile"/>
            <field name="binding_model_id" ref="model_user_profile"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">records.action_archive()</field>
        </record>

        <!-- Window Action -->
        <record id="action_user_profile" model="ir.actions.act_window">
            <field name="name">Users</field>
            <field name="res_model">user.profile</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'active_test': False}</field>
        </record>
    </data>
</odoo>
